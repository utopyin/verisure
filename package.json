  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/tsgo": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "turbo": "^2.9.16",
    "ultracite": "^7.8.3"
  },
  "packageManager": "bun@1.3.13"
