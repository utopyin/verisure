{
  "name": "verisure",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@effect/tsgo": "0.14.5",
      "@typescript/native-preview": "7.0.0-dev.20260421.2",
      "drizzle-orm": "1.0.0-rc.1",
      "drizzle-kit": "1.0.0-rc.1",
      "effect": "4.0.0-beta.83",
      "@effect/platform-browser": "4.0.0-beta.83",
      "@effect/vitest": "4.0.0-beta.83",
      "vite": "8.0.16",
      "vitest": "4.1.9",
      "@cloudflare/workers-types": "^4.20260608.1",
      "better-auth": "^1.6.19"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
