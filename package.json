{
  "name": "verisure",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "alchemy dev",
    "dev:turbo": "turbo run dev",
    "build": "turbo run build",
    "check:types": "tsc && turbo run check:types",
    "check": "bun run check:types",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "logs": "alchemy logs",
    "tail": "alchemy tail",
    "test": "bun test ./packages ./apps",
    "test:turbo": "turbo run test",
    "typecheck": "bun run check:types"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "alchemy": "link:alchemy",
    "effect": "4.0.0-beta.78",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.9.16",
    "typescript": "^5"
  }
}
