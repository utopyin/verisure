{
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "repos/**"
  ],
  "format_on_save": "on",
  "formatter": "language_server",
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!biome",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TSX": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!biome",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TypeScript": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!biome",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    }
  }
}
