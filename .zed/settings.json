{
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "repos/**"
  ],
  "format_on_save": "on",
  "formatter": "language_server",
  "lsp": {
    "effect-tsgo": {
      "settings": {
        "package_version": "0.14.4"
      }
    },
    "typescript-language-server": {
      "settings": {
        "typescript": {
          "preferences": {
            "includePackageJsonAutoImports": "on"
          }
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "flags": {},
          "fmt.configPath": null,
          "fmt.experimental": true,
          "run": "onSave",
          "typeAware": false,
          "unusedDisableDirectives": false
        }
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "run": "onType",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TSX": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TypeScript": {
      "language_servers": [
        "effect-tsgo",
        "!eslint",
        "!tsgo",
        "!vtsls",
        "!typescript-language-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports.oxc": true
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    }
  }
}
